---
import Layout from './Layout.astro';

interface Props {
  title: string;
  active?: 'links' | 'create' | 'settings';
}

const { title, active = 'links' } = Astro.props;

const navItems = [
  { id: 'links', label: 'Links', href: '/dashboard', icon: '&#128279;' },
  { id: 'create', label: 'Create', href: '/dashboard/create', icon: '&#10010;' },
  { id: 'settings', label: 'Settings', href: '/dashboard/settings', icon: '&#9881;' },
] as const;
---

<Layout title={`${title} — clipr`}>
  <div class="flex min-h-screen">
    <aside style="position:fixed;left:0;top:0;height:100%;width:15rem;display:flex;flex-direction:column;border-right:1px solid var(--color-border-default);background:var(--color-bg-surface);">
      <div style="display:flex;align-items:center;gap:0.5rem;border-bottom:1px solid var(--color-border-default);padding:1rem 1.25rem;">
        <a href="/" style="display:flex;align-items:center;gap:0.5rem;font-size:1.125rem;font-weight:600;letter-spacing:-0.025em;text-decoration:none;color:var(--color-text-primary);">
          <span style="display:inline-flex;height:1.75rem;width:1.75rem;align-items:center;justify-content:center;border-radius:0.375rem;background:var(--color-brand);color:#fff;font-size:0.875rem;font-weight:700;">c</span>
          <span>clipr</span>
        </a>
      </div>
      <nav style="flex:1;padding:1rem 0.75rem;">
        {navItems.map((item) => (
          <a
            href={item.href}
            style={`display:flex;align-items:center;gap:0.75rem;border-radius:0.5rem;padding:0.5rem 0.75rem;margin-bottom:0.25rem;font-size:0.875rem;text-decoration:none;transition:all 0.2s;${
              active === item.id
                ? `background:var(--color-bg-elevated);color:var(--color-text-primary);font-weight:500;`
                : `color:var(--color-text-secondary);`
            }`}
          >
            <span style="font-size:1rem;" set:html={item.icon} />
            {item.label}
          </a>
        ))}
      </nav>
      <div style="border-top:1px solid var(--color-border-default);padding:1rem 1.25rem;">
        <a href="/" style="font-size:0.75rem;color:var(--color-text-secondary);text-decoration:none;">&larr; Back to site</a>
      </div>
    </aside>

    <main style="margin-left:15rem;flex:1;padding:2rem;">
      <slot />
    </main>
  </div>
</Layout>
