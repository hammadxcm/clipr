---
import { apiExports } from '../../data/site';
import { getTranslation } from '../../i18n/index';
import SectionHeader from '../common/SectionHeader.astro';
import Terminal from './Terminal.astro';

interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;
const t = getTranslation(locale);

// Syntax-highlighted code — each span gets a color class
// Colors: kw=keyword, fn=function, str=string, cm=comment, op=operator, vr=variable, nr=number

---

<section id="api">
  <div class="section">
    <SectionHeader label={t('api.label')} title={t('api.title')} />

    <p class="api-subtitle reveal">{t('api.subtitle')}</p>

    <div class="api-grid">
      <!-- LEFT: Exports list -->
      <div class="api-exports reveal-left">
        <h3 class="api-exports-title">@clipr/core exports</h3>
        <ul class="api-exports-list">
          {apiExports.map((item, i) => (
            <li class="api-export-item" style={`--stagger-index: ${i};`}>
              <code class="api-export-name">{item.name}</code>
              <span class="api-export-desc">{item.desc}</span>
            </li>
          ))}
        </ul>

        <div class="api-install-hint">
          <span class="terminal-prompt">$</span>
          <code>npm install @clipr/core</code>
        </div>
      </div>

      <!-- RIGHT: Code example -->
      <div class="api-code shadow-md reveal-right">
        <Terminal title="@clipr/core — usage example">
          <pre class="code-block"><code><span class="c-cm">// app.ts</span>
<span class="c-kw">import</span> {'{'} <span class="c-fn">JsonBackend</span>, <span class="c-fn">validateUrl</span>, <span class="c-fn">appendUtm</span> {'}'} <span class="c-kw">from</span> <span class="c-str">'@clipr/core'</span>;

<span class="c-kw">const</span> <span class="c-vr">backend</span> <span class="c-op">=</span> <span class="c-kw">new</span> <span class="c-fn">JsonBackend</span>(<span class="c-str">'./urls.json'</span>);

<span class="c-cm">// Validate and shorten</span>
<span class="c-kw">const</span> <span class="c-vr">url</span> <span class="c-op">=</span> <span class="c-str">'https://example.com/launch'</span>;
<span class="c-kw">if</span> (<span class="c-fn">validateUrl</span>(<span class="c-vr">url</span>)) {'{'}
  <span class="c-kw">const</span> <span class="c-vr">slug</span> <span class="c-op">=</span> <span class="c-kw">await</span> <span class="c-vr">backend</span>.<span class="c-fn">shorten</span>(<span class="c-vr">url</span>);
  <span class="c-vr">console</span>.<span class="c-fn">log</span>(<span class="c-str">`Created: </span><span class="c-op">${'$'}{</span><span class="c-vr">slug</span><span class="c-op">}</span><span class="c-str">`</span>);
{'}'}

<span class="c-cm">// Append UTM params</span>
<span class="c-kw">const</span> <span class="c-vr">tracked</span> <span class="c-op">=</span> <span class="c-fn">appendUtm</span>(<span class="c-vr">url</span>, {'{'}
  <span class="c-vr">source</span>: <span class="c-str">'twitter'</span>,
  <span class="c-vr">medium</span>: <span class="c-str">'social'</span>,
{'}'});</code></pre>
        </Terminal>
      </div>
    </div>
  </div>
</section>

<style>
  .api-subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 1rem;
    margin: 0 auto 2.5rem;
  }

  .api-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 2.5rem;
    align-items: start;
    max-width: 1000px;
    margin: 0 auto;
  }

  /* Exports list */
  .api-exports {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .api-exports-title {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .api-exports-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .api-export-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.875rem 1rem;
    border-radius: var(--radius-sm);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .api-export-item:hover {
    border-color: var(--color-border-hover);
    transform: translateX(4px);
  }

  .api-export-name {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-brand);
    background: color-mix(in srgb, var(--color-brand) 8%, transparent);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    width: fit-content;
  }

  .api-export-desc {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    padding-left: 0.1rem;
  }

  .api-install-hint {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--color-brand) 5%, transparent);
    border: 1px dashed color-mix(in srgb, var(--color-brand) 20%, transparent);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin-top: 0.5rem;
  }

  .api-install-hint code {
    color: var(--color-text-accent);
  }

  /* Syntax highlighting colors */
  .code-block {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.8;
    white-space: pre;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .code-block code {
    font-family: inherit;
  }

  .c-kw { color: #c792ea; }              /* keywords: import, const, if, await, new, from */
  .c-fn { color: #82aaff; }              /* functions: JsonBackend, validateUrl, appendUtm */
  .c-str { color: #c3e88d; }             /* strings: 'text' */
  .c-cm { color: #546e7a; font-style: italic; } /* comments */
  .c-op { color: #89ddff; }              /* operators: =, ${} */
  .c-vr { color: #eeffff; }              /* variables: url, backend, slug */
  .c-nr { color: #f78c6c; }              /* numbers */

  /* Theme-aware overrides */
  [data-theme="matrix"] .c-kw { color: #00ff41; }
  [data-theme="matrix"] .c-fn { color: #39ff14; }
  [data-theme="matrix"] .c-str { color: #7cfc00; }
  [data-theme="matrix"] .c-cm { color: #00c818; }

  [data-theme="dracula"] .c-kw { color: #ff79c6; }
  [data-theme="dracula"] .c-fn { color: #50fa7b; }
  [data-theme="dracula"] .c-str { color: #f1fa8c; }

  [data-theme="arctic"] .c-kw { color: #0369a1; }
  [data-theme="arctic"] .c-fn { color: #0ea5e9; }
  [data-theme="arctic"] .c-str { color: #059669; }
  [data-theme="arctic"] .c-vr { color: #0f172a; }
  [data-theme="arctic"] .c-cm { color: #94a3b8; }

  /* Code side */
  .api-code {
    position: relative;
  }

  .api-code::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 13px;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-brand) 15%, transparent),
      transparent 50%
    );
    z-index: -1;
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .api-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .api-exports {
      order: 2;
    }

    .api-code {
      order: 1;
    }
  }
</style>
