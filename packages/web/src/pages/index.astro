---
import Footer from '../components/common/Footer.astro';
import Nav from '../components/common/Nav.astro';
import Features from '../components/hero/Features.astro';
import Hero from '../components/hero/Hero.astro';
import Api from '../components/showcase/Api.astro';
import Comparison from '../components/showcase/Comparison.astro';
import Demo from '../components/showcase/Demo.astro';
import Install from '../components/showcase/Install.astro';
import Marquee from '../components/showcase/Marquee.astro';
import Shorten from '../components/showcase/Shorten.astro';
import Stats from '../components/showcase/Stats.astro';
import Toast from '../components/ui/Toast.astro';
import Layout from '../layouts/Layout.astro';
