function repeat<T>(arr: T[], times: number): T[] {
  const result: T[] = [];
  for (let i = 0; i < times; i++) result.push(...arr);
  return result;
}
---

<section class="marquee-section">
  <!-- Row 1: Left to right -->
  <div class="marquee-row">
    <div class="marquee-mask">
      <div class="marquee-track marquee-forward">
        {repeat(techsRow1, 4).map((tech) => (
          <span class="marquee-item">
            <span class="marquee-icon" set:html={tech.svg} />
            <span class="marquee-name">{tech.name}</span>
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- Row 2: Right to left -->
  <div class="marquee-row">
    <div class="marquee-mask">
      <div class="marquee-track marquee-reverse">
        {repeat(techsRow2, 4).map((tech) => (
          <span class="marquee-item">
            <span class="marquee-icon" set:html={tech.svg} />
            <span class="marquee-name">{tech.name}</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-section {
    padding: 1.25rem 0;
    border-top: 1px solid var(--color-border-default);
    border-bottom: 1px solid var(--color-border-default);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    overflow: hidden;
  }

  .marquee-mask {
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    overflow: hidden;
  }

  .marquee-track {
    display: flex;
    gap: 2.5rem;
    width: max-content;
  }

  .marquee-forward {
    animation: marquee-scroll 25s linear infinite;
  }

  .marquee-reverse {
    animation: marquee-scroll 30s linear infinite reverse;
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    opacity: 0.35;
    transition: opacity 0.3s ease, color 0.3s ease, transform 0.3s ease;
    cursor: default;
  }

  .marquee-item:hover {
    opacity: 1;
    color: var(--color-brand);
    transform: scale(1.05);
  }

  .marquee-icon {
    display: inline-flex;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .marquee-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .marquee-name {
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-forward,
    .marquee-reverse {
      animation: none;
    }
  }
</style>
