---
interface Props {
  text: string;
  label?: string;
}

const { text, label = 'Copy to clipboard' } = Astro.props;
---

<button
  class="copy-btn"
  data-copy={text}
  aria-label={label}
  style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border:1px solid var(--color-border-default);border-radius:0.375rem;background:transparent;color:var(--color-text-secondary);cursor:pointer;transition:all 0.2s;flex-shrink:0;"
>
  <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
  </svg>
  <svg class="check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
    <polyline points="20 6 9 17 4 12"></polyline>
  </svg>
</button>

<style>
  .copy-btn:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text-primary);
  }
  .copy-btn.copied {
    color: #28c840;
    border-color: #28c840;
  }
</style>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy');
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      const copyIcon = btn.querySelector('.copy-icon') as HTMLElement;
      const checkIcon = btn.querySelector('.check-icon') as HTMLElement;
      if (copyIcon && checkIcon) {
        copyIcon.style.display = 'none';
        checkIcon.style.display = 'block';
        btn.classList.add('copied');
        setTimeout(() => {
          copyIcon.style.display = 'block';
          checkIcon.style.display = 'none';
          btn.classList.remove('copied');
        }, 1500);
      }
    });
  });
</script>
