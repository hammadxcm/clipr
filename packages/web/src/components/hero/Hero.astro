---
import { heroRotatingWords, siteConfig } from '../../data/site';
import { getTranslation } from '../../i18n/index';
import Terminal from '../showcase/Terminal.astro';

interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;
const t = getTranslation(locale);
---

<section id="hero" class="hero" aria-label="Hero">
  <!-- Background glow orb -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-orb"></div>
    <div class="hero-orb hero-orb--secondary"></div>
  </div>

  <!-- Floating slug labels -->
  <div class="hero-floats" aria-hidden="true">
    <span class="hero-float" style="--float-delay: 0s; --float-x: 8%; --float-y: 20%;">/docs</span>
    <span class="hero-float" style="--float-delay: 1.2s; --float-x: 85%; --float-y: 15%;">/launch</span>
    <span class="hero-float" style="--float-delay: 2.4s; --float-x: 12%; --float-y: 72%;">/promo</span>
    <span class="hero-float" style="--float-delay: 0.6s; --float-x: 78%; --float-y: 68%;">/blog</span>
    <span class="hero-float" style="--float-delay: 1.8s; --float-x: 50%; --float-y: 8%;">/api</span>
    <span class="hero-float" style="--float-delay: 3s; --float-x: 92%; --float-y: 42%;">/gh</span>
  </div>

  <div class="hero-container section">
    <div class="hero-grid">
      <!-- LEFT COLUMN -->
      <div class="hero-content reveal">
        <div class="hero-badge glass">
          <span class="hero-badge-dot"></span>
          {t('hero.badge')}
        </div>

        <h1 class="hero-title">
          {t('hero.title')}<br />
          <span class="hero-rotating gradient-text gradient-text-animate" aria-live="polite">
            {heroRotatingWords.map((word, i) => (
              <span
                class:list={['hero-word', { 'hero-word--active': i === 0 }]}
                data-index={i}
              >
                {word}
              </span>
            ))}
          </span>
        </h1>

        <p class="hero-description">
          {t('hero.description')}
        </p>

        <div class="hero-actions">
          <a href="#install" class="hero-btn hero-btn--primary btn btn-primary">
            {t('hero.cta')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="hero-btn hero-btn--outline btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            {t('hero.github')}
          </a>
        </div>
      </div>

      <!-- RIGHT COLUMN: Terminal demo -->
      <div class="hero-terminal animate-border-glow reveal" style="transition-delay: 0.2s;">
        <Terminal title="clipr">
          <div id="hero-terminal-body">
            <div class="terminal-line terminal-command">$ clipr shorten https://example.com/very/long/path</div>
            <div class="terminal-line terminal-success">&check; Shortened https://example.com/very/long/path</div>
            <div class="terminal-line terminal-output">  https://clpr.sh/x7k9m2</div>
          </div>
        </Terminal>
      </div>
    </div>
  </div>

  <div class="scroll-indicator" style="position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);">
    <span class="scroll-indicator-dot"></span>
    <span style="font-size:0.7rem;color:var(--color-text-secondary);">scroll</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 85vh;
    padding-top: 5rem;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Background orbs */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-orb {
    position: absolute;
    top: 15%;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--color-brand) 12%, transparent) 0%,
      transparent 70%
    );
    filter: blur(80px);
    animation: blob-float 20s ease-in-out infinite;
  }

  .hero-orb--secondary {
    top: 40%;
    left: 30%;
    width: 400px;
    height: 300px;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--color-brand-light) 8%, transparent) 0%,
      transparent 70%
    );
    animation-delay: -7s;
    animation-duration: 25s;
  }

  /* Floating slug labels */
  .hero-floats {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-float {
    position: absolute;
    left: var(--float-x);
    top: var(--float-y);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: color-mix(in srgb, var(--color-brand) 25%, transparent);
    padding: 0.25rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-brand) 8%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-brand) 3%, transparent);
    animation: float 8s ease-in-out infinite;
    animation-delay: var(--float-delay);
  }

  /* Container */
  .hero-container {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* Left content */
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    padding: 0.375rem 1rem;
    border-radius: 999px;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .hero-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #28c840;
    box-shadow: 0 0 8px rgba(40, 200, 64, 0.5);
    animation: watch-blink 2s ease-in-out infinite;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.02em;
    text-shadow: 0 0 40px color-mix(in srgb, var(--color-brand) 20%, transparent);
  }

  .hero-rotating {
    display: inline-block;
    position: relative;
    min-width: 280px;
    height: 1.15em;
    vertical-align: bottom;
  }

  .hero-word {
    position: absolute;
    left: 0;
    top: 0;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
    white-space: nowrap;
  }

  .hero-word--active {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 480px;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.3s var(--ease-out-expo);
    min-height: 44px;
  }

  .hero-btn--primary {
    background: var(--color-brand);
    color: #fff;
    border: 1px solid var(--color-brand);
    box-shadow: 0 0 20px color-mix(in srgb, var(--color-brand) 30%, transparent);
  }

  .hero-btn--primary:hover {
    background: var(--color-brand-light);
    border-color: var(--color-brand-light);
    box-shadow: 0 0 30px color-mix(in srgb, var(--color-brand) 40%, transparent);
    transform: translateY(-2px);
  }

  .hero-btn--outline {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-default);
  }

  .hero-btn--outline:hover {
    border-color: var(--color-border-hover);
    background: color-mix(in srgb, var(--color-brand) 5%, transparent);
    transform: translateY(-2px);
  }

  /* Right terminal */
  .hero-terminal {
    position: relative;
  }

  .hero-terminal::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 13px;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-brand) 20%, transparent),
      transparent 50%,
      color-mix(in srgb, var(--color-brand-light) 10%, transparent)
    );
    z-index: -1;
    opacity: 0.6;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }

    .hero-content {
      align-items: center;
    }

    .hero-description {
      max-width: 100%;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-float {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .hero {
      min-height: auto;
      padding-top: 6rem;
      padding-bottom: 3rem;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
    }

    .hero-btn {
      justify-content: center;
    }
  }
</style>

<script>
  import { heroRotatingWords } from '../../data/site';
  import { initTerminalDemo } from '../../scripts/terminal-demo';

  // Rotating word animation
  function initRotatingWords(): void {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const words = document.querySelectorAll('.hero-word');
    if (words.length === 0) return;

    let current = 0;

    setInterval(() => {
      words[current].classList.remove('hero-word--active');
      current = (current + 1) % words.length;
      words[current].classList.add('hero-word--active');
    }, 2800);
  }

  initRotatingWords();
  initTerminalDemo();
</script>
