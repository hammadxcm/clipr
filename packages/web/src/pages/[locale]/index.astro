---
import Footer from '../../components/common/Footer.astro';
import Nav from '../../components/common/Nav.astro';
import Features from '../../components/hero/Features.astro';
import Hero from '../../components/hero/Hero.astro';
import Api from '../../components/showcase/Api.astro';
import Comparison from '../../components/showcase/Comparison.astro';
import Demo from '../../components/showcase/Demo.astro';
import Install from '../../components/showcase/Install.astro';
import Marquee from '../../components/showcase/Marquee.astro';
import Shorten from '../../components/showcase/Shorten.astro';
import Stats from '../../components/showcase/Stats.astro';
import Toast from '../../components/ui/Toast.astro';
import { locales } from '../../i18n/index';
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return locales.filter((l) => l !== 'en').map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
---

<Layout title="clipr" locale={locale}>
  <Nav locale={locale} />
  <main>
    <Hero locale={locale} />
    <Marquee />
    <Shorten locale={locale} />
    <Features locale={locale} />
    <Stats />
    <Comparison locale={locale} />
    <Install locale={locale} />
    <Demo locale={locale} />
    <Api locale={locale} />
  </main>
  <Footer />
  <Toast />
</Layout>
