---
import { footerLinks, siteConfig } from '../../data/site';
---

<footer class="accent-border-top" style="padding:3rem 0;margin-top:4rem;">
  <div style="max-width:1200px;margin:0 auto;padding:0 1.5rem;">
    <div style="display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:2rem;">
      <!-- Brand -->
      <div>
        <a href="/" style="display:flex;align-items:center;gap:0.5rem;text-decoration:none;font-size:1.125rem;font-weight:600;color:var(--color-text-primary);margin-bottom:1rem;">
          <span style="display:inline-flex;height:1.5rem;width:1.5rem;align-items:center;justify-content:center;border-radius:0.375rem;background:var(--color-brand);color:#fff;font-size:0.625rem;font-weight:700;">c</span>
          <span>clipr</span>
        </a>
        <p style="font-size:0.875rem;color:var(--color-text-secondary);line-height:1.6;max-width:280px;">
          {siteConfig.description}
        </p>
        <!-- Social -->
        <div style="display:flex;gap:0.75rem;margin-top:1rem;">
          <a href={siteConfig.github} target="_blank" rel="noopener" aria-label="GitHub" style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:0.375rem;border:1px solid var(--color-border-default);color:var(--color-text-secondary);text-decoration:none;transition:all 0.2s;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 style="font-size:0.9375rem;font-weight:600;color:var(--color-text-primary);margin-bottom:1rem;">Quick Links</h3>
        {footerLinks.quickLinks.map((link) => (
          <a href={link.href} style="display:block;font-size:0.875rem;color:var(--color-text-secondary);text-decoration:none;padding:0.25rem 0;transition:color 0.2s;">
            {link.label}
          </a>
        ))}
      </div>

      <!-- Resources -->
      <div>
        <h3 style="font-size:0.9375rem;font-weight:600;color:var(--color-text-primary);margin-bottom:1rem;">Resources</h3>
        {footerLinks.resources.map((link) => (
          <a href={link.href} target="_blank" rel="noopener" style="display:block;font-size:0.875rem;color:var(--color-text-secondary);text-decoration:none;padding:0.25rem 0;transition:color 0.2s;">
            {link.label}
          </a>
        ))}
      </div>

      <!-- Connect -->
      <div>
        <h3 style="font-size:0.9375rem;font-weight:600;color:var(--color-text-primary);margin-bottom:1rem;">Connect</h3>
        {footerLinks.connect.map((link) => (
          <a href={link.href} target="_blank" rel="noopener" style="display:block;font-size:0.875rem;color:var(--color-text-secondary);text-decoration:none;padding:0.25rem 0;transition:color 0.2s;">
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--color-border-default);display:flex;align-items:center;justify-content:space-between;">
      <span style="font-size:0.75rem;color:var(--color-text-secondary);">
        clipr &middot; MIT License
      </span>
    </div>
  </div>
</footer>

<style>
  footer a:hover {
    color: var(--color-brand) !important;
  }

  @media (max-width: 768px) {
    footer > div > div:first-child {
      grid-template-columns: 1fr 1fr !important;
    }
  }

  @media (max-width: 480px) {
    footer > div > div:first-child {
      grid-template-columns: 1fr !important;
    }
  }
</style>
