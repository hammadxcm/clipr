{
  "name": "@clipr/worker",
  "version": "0.0.11",
  "description": "Cloudflare Worker for clipr URL redirects",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clipr/core": "workspace:*",
    "hono": "^4.12.10",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@types/node": "^25.5.2",
    "@types/qrcode": "^1.5.5",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hammadxcm/clipr",
    "directory": "packages/worker"
