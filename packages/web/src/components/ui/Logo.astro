---
interface Props {
  size?: number;
}

const { size = 28 } = Astro.props;
---

<span class="logo-icon" aria-hidden="true" style={`width:${size}px;height:${size}px;`}>
  <svg class="logo-svg" width={size} height={size} viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Outer glow ring -->
    <circle cx="32" cy="32" r="30" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 4" class="logo-ring" opacity="0.15"/>

    <!-- Link 1 (top-left) -->
    <path d="M20 28C20 24 24 20 28 20L36 20C40 20 40 28 36 28L28 28C24 28 20 32 20 28Z" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="logo-link logo-link-1"/>

    <!-- Link 2 (bottom-right) -->
    <path d="M44 36C44 40 40 44 36 44L28 44C24 44 24 36 28 36L36 36C40 36 44 32 44 36Z" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="logo-link logo-link-2"/>

    <!-- Center connector dot -->
    <circle cx="32" cy="32" r="3" fill="var(--color-brand)" class="logo-dot"/>

    <!-- Small accent dots -->
    <circle cx="22" cy="24" r="1.5" fill="currentColor" opacity="0.3" class="logo-accent"/>
    <circle cx="42" cy="40" r="1.5" fill="currentColor" opacity="0.3" class="logo-accent"/>
  </svg>
</span>

<style>
  .logo-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand);
    animation: logoGlow 4s ease-in-out infinite;
    will-change: filter;
    transition: filter 0.3s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .logo-icon:hover {
    filter: drop-shadow(0 0 6px var(--color-brand))
            drop-shadow(0 0 14px color-mix(in srgb, var(--color-brand) 40%, transparent));
    transform: scale(1.1);
  }

  @keyframes logoGlow {
    0%, 100% { filter: drop-shadow(0 0 0px transparent); }
    50% { filter: drop-shadow(0 0 5px color-mix(in srgb, var(--color-brand) 30%, transparent)); }
  }

  .logo-dot {
    animation: logoDotPulse 2s ease-in-out infinite;
  }

  @keyframes logoDotPulse {
    0%, 100% { r: 3; opacity: 1; }
    50% { r: 4; opacity: 0.8; }
  }

  .logo-link {
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
  }

  .logo-icon:hover .logo-link-1 {
    transform: translate(-2px, -2px);
  }

  .logo-icon:hover .logo-link-2 {
    transform: translate(2px, 2px);
  }

  .logo-ring {
    animation: logoRingSpin 20s linear infinite;
  }

  @keyframes logoRingSpin {
    from { transform: rotate(0deg); transform-origin: 32px 32px; }
    to { transform: rotate(360deg); transform-origin: 32px 32px; }
  }

  .logo-accent {
    transition: opacity 0.3s ease;
  }

  .logo-icon:hover .logo-accent {
    opacity: 0.8;
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-icon,
    .logo-dot,
    .logo-ring {
      animation: none;
    }
    .logo-icon:hover {
      transform: none;
    }
    .logo-icon:hover .logo-link-1,
    .logo-icon:hover .logo-link-2 {
      transform: none;
    }
  }
</style>
